universe                = docker
docker_image            = nvidia/cuda:11.4.3-runtime-ubuntu20.04
executable              = execute.sh

# Python file to run, can also include arguments
arguments               = main.py --action extract --model facex --strategy no_aug

# Paths to output, error, and log files
# Make sure all the parent directories exist
output                  = /home/hlcv_team006/condor_logs/extract.$(ClusterId).$(ProcId).out
error                   = /home/hlcv_team006/condor_logs/extract.$(ClusterId).$(ProcId).err
log                     = /home/hlcv_team006/condor_logs/extract.$(ClusterId).log

should_transfer_files   = YES

# Remove this when using interactive mode
when_to_transfer_output = ON_EXIT

request_GPUs = 1
request_CPUs = 1
request_memory = 6G
requirements = UidDomain == "cs.uni-saarland.de" 
+WantGPUHomeMounted = true
queue 1